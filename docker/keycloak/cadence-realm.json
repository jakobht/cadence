{
  "realm": "cadence",
  "enabled": true,
  "displayName": "Cadence",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "roles": {
    "realm": [
      { "name": "cadence-read",    "description": "Read-only access to Cadence domains" },
      { "name": "cadence-write",   "description": "Read+write access to Cadence domains" },
      { "name": "cadence-process", "description": "Worker poll access to Cadence domains" },
      { "name": "cadence-admin",   "description": "Bypass per-domain checks (admin claim)" }
    ]
  },

  "clients": [
    {
      "clientId": "cadence-server",
      "name": "Cadence Server",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "attributes": {
        "access.token.lifespan": "3600"
      },
      "protocolMappers": [
        {
          "name": "audience-cadence-server",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "cadence-server",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "cadence-admin-attribute",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "cadence_admin",
            "claim.name": "cadence_admin",
            "jsonType.label": "boolean",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Example",
      "email": "alice@example.com",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["cadence-read", "cadence-write"]
    },
    {
      "username": "bob-worker",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Worker",
      "email": "bob@example.com",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["cadence-process"]
    },
    {
      "username": "admin-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@example.com",
      "attributes": {
        "cadence_admin": ["true"]
      },
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["cadence-admin"]
    }
  ]
}
